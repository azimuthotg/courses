# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FORCE_SCRIPT_NAME=
STATIC_URL=/static/
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Database (MySQL)
DB_NAME=lms_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# LDAP (set LDAP_ENABLED=True when AD credentials are ready)
LDAP_ENABLED=False
LDAP_SERVER_URI=ldap://ad.npu.ac.th
LDAP_BIND_DN=CN=svc-ldap,OU=ServiceAccounts,DC=npu,DC=ac,DC=th
LDAP_BIND_PASSWORD=
LDAP_USER_BASE_DN=DC=npu,DC=ac,DC=th

# Student authentication via NPU API
NPU_STUDENT_AUTH_ENABLED=True
NPU_STUDENT_AUTH_URL=https://api.npu.ac.th/v2/ldap/auth_and_get_student/
NPU_STUDENT_AUTH_TOKEN=
NPU_STUDENT_AUTH_TIMEOUT=10
NPU_STUDENT_CODE_LENGTH=12

# Waitress (production)
WAITRESS_HOST=127.0.0.1
WAITRESS_PORT=8002
WAITRESS_THREADS=8

# --- Production overrides ---
# SECRET_KEY=<generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
# DEBUG=False
# ALLOWED_HOSTS=lib.npu.ac.th,127.0.0.1
# FORCE_SCRIPT_NAME=/courses
# STATIC_URL=/courses/static/
# CSRF_TRUSTED_ORIGINS=https://lib.npu.ac.th
# LDAP_ENABLED=True
